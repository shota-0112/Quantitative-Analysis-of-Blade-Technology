# 1. ggplot2パッケージを読み込む
library(ggplot2)
library(showtext) # 追加したパッケージを読み込む

# 1. WindowsのメイリオフォントをRに登録する
# font_add("Rで使う好きな名前", "Windowsに入っているフォントのファイル名")
font_add("my_meiryo", "meiryo.ttc")

# 2. showtextの機能をオンにする（これ以降のグラフでフォントが有効になります）
showtext_auto()

# 2. CSVデータを読み込む
# ※ "C:/..." の部分は、ファイルが保存されている実際のパスに書き換えてください。
# 例: C:\Users\iwash\OneDrive\デスクトップ\修士論文\angle_for_Rstudio.csv
my_data <- read.csv("C:/Users/iwash/OneDrive/デスクトップ/修士論文/bladelist_for_R.csv")

# 3. ちゃんと読み込めたか最初の数行を確認
head(my_data)

# 4. ヒストグラムを描画する
ggplot(data = my_data, aes(x = angle)) +
  # breaksでデータ区間（30から90まで10刻み）を指定
  geom_histogram(breaks = seq(30, 90, by = 5), fill = "grey", color = "black") +
  # タイトルと軸ラベルの設定
  labs(
    title = "対象資料全点の交差角度",
    x = "角度",
    y = "度数"
  ) +
  # X軸の目盛りを明示的に指定（30, 40, 50...）
  scale_x_continuous(breaks = seq(30, 90, by = 5)) +
  # 背景をシンプルなデザインにする
  theme_minimal() +
  # タイトルを中央揃えにする（お好みで）
  theme(
    text = element_text(family = "my_meiryo"),
    plot.title = element_text(hjust = 0.5),
    axis.title.x = element_text(margin = margin(t = 12)),
    axis.title.y = element_text(margin = margin(r = 12)),
    )

